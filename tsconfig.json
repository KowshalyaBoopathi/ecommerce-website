{
    "include": ["tests/**/*.ts", "tests/*.ts", "tests/**/**/**/**/*.ts", "tests/**/**/**/*.ts", "tests/**/**/*.ts", "tests/**/*.ts"],
    "exclude": ["node_modules", "eslint.config.mts", "playwright.config.ts"],
    "compilerOptions": {
        "paths": {},
        "target": "es2022",
        "module": "Node16",
        "moduleResolution": "node16",
        "noEmit": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "allowImportingTsExtensions": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "skipLibCheck": true,
        "isolatedModules": true,
        "sourceMap": true,
        "rootDir": "./",
        "outDir": "./dist"
    },
    "ts-node": {
        "transpileOnly": true
    }
}
